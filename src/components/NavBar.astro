---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/writeups', label: 'Writeups' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="border-b border-zinc-800">
  <nav class="max-w-3xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="font-mono text-sm text-zinc-100 hover:text-white">
      Jeff Hidalgo
    </a>
    <ul class="flex gap-6 text-sm text-zinc-400">
      {links.slice(1).map((link) => (
        <li>
          <a href={link.href} class="hover:text-zinc-100 transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>