        <a href="mailto:jhida.sec@gmail.com" class="text-zinc-100 hover:text-white ml-2">jhida.sec.com</a>
      </li>
      <li>
        <span class="text-zinc-500">github</span>
        <a href="https://github.com/jhidasec" class="text-zinc-100 hover:text-white ml-2">github.com/jhidasec</a>
      </li>
      <li>
        <span class="text-zinc-500">linkedin</span>
